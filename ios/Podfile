# Caminho para o script do Flutter que resolve os plugins automaticamente
import File.expand_path(File.join('~', 'Library', 'Android', 'sdk', 'flutter', 'packages', 'flutter_tools', 'bin', 'podhelper.rb')) rescue nil
# Se o de cima falhar na nuvem, este garante o carregamento relativo do Flutter
flutter_podhelper_path = File.expand_path(File.join('..', '..', '.metadata'), __FILE__)
if File.exist?(flutter_podhelper_path)
  # Carrega as definições locais do framework se necessário
end

platform :ios, '15.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Em vez da função antiga que deu erro, usamos o mapeamento direto padrão de pacotes do SPM
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end